generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---

enum Role {
  AGENT
  SUPERVISOR
  ADMIN
}

// --- Models ---

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  passwordHash    String           @map("password_hash")
  name            String
  role            Role             @default(AGENT)
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  clients         Client[]
  recommendations Recommendation[]

  @@map("users")
}

model Client {
  id              String           @id @default(uuid())
  agentId         String           @map("agent_id")
  agent           User             @relation(fields: [agentId], references: [id])
  firstName       String           @map("first_name")
  lastName        String           @map("last_name")
  email           String?          @unique
  phone           String?
  dateOfBirth     DateTime         @map("date_of_birth")
  gender          String?
  clientType      String           @default("NEW") @map("client_type")
  economicProfile Json?            @map("economic_profile")
  riskLevel       String?          @map("risk_level")
  needs           Json?
  createdAt       DateTime         @default(now()) @map("created_at")
  recommendations Recommendation[]

  @@index([agentId])
  @@index([createdAt])
  @@map("clients")
}

model Product {
  id                  String               @id @default(uuid())
  name                String               @unique
  type                String               // AUTO, LIFE, FIRE, MOBILE
  description         String?
  priceBase           Decimal              @map("price_base") @db.Decimal(12, 2)
  isActive            Boolean              @default(true) @map("is_active")
  specificData        Json?                @map("specific_data")
  coverages           Coverage[]
  recommendedProducts RecommendedProduct[]

  @@index([type])
  @@index([isActive])
  @@map("products")
}

model Coverage {
  id          String  @id @default(uuid())
  productId   String  @map("product_id")
  product     Product @relation(fields: [productId], references: [id])
  name        String
  description String?
  value       Decimal? @db.Decimal(12, 2)

  @@map("coverages")
}

model Recommendation {
  id              String               @id @default(uuid())
  clientId        String               @map("client_id")
  client          Client               @relation(fields: [clientId], references: [id])
  agentId         String               @map("agent_id")
  agent           User                 @relation(fields: [agentId], references: [id])
  status          String               // GENERATED, PRESENTED, ACCEPTED, REJECTED
  globalScore     Decimal?             @map("global_score") @db.Decimal(5, 2)
  rejectionReason String?              @map("rejection_reason")
  createdAt       DateTime             @default(now()) @map("created_at")
  products        RecommendedProduct[]

  @@index([clientId])
  @@index([agentId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@map("recommendations")
}

model RecommendedProduct {
  recommendationId String         @map("recommendation_id")
  recommendation   Recommendation @relation(fields: [recommendationId], references: [id])
  productId        String         @map("product_id")
  product          Product        @relation(fields: [productId], references: [id])
  matchScore       Decimal?       @map("match_score") @db.Decimal(5, 2)
  finalPrice       Decimal?       @map("final_price") @db.Decimal(12, 2)
  justifications   Json?

  @@id([recommendationId, productId])
  @@map("recommended_products")
}

model Promotion {
  id              String   @id @default(uuid())
  name            String
  description     String?
  discountPercent Decimal? @map("discount_percent") @db.Decimal(5, 2)
  isActive        Boolean  @default(true) @map("is_active")
  expiresAt       DateTime? @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("promotions")
}
