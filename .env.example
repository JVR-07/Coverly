# ==========================================
# VARIABLES LOCALES / PRODUCCIÓN - COVERLY
# ==========================================

# 1. Base de Datos (Conexión Prisma o Drizzle)
# Utilizada por Next.js Core. En producción, AWS RDS.
DATABASE_URL="postgresql://user:password@localhost:5432/coverly_db?schema=public"

# 2. Secretos y JWT
# Semilla obligatoria para asegurar las cookies y tokens de login
JWT_SECRET="generate_a_strong_random_string_here_like_openssl_rand_base64_32"
# Si se usa NextAuth alternativamente:
NEXTAUTH_SECRET="your-super-secret-nextauth-key"
NEXTAUTH_URL="http://localhost:3000"

# 3. Comunicación a Microservicios
# Motor inteligente (Docker: "engine:8000". Local "localhost:8000")
ENGINE_API_URL="http://127.0.0.1:8000/api/v1/engine/evaluate"

# 4. Entorno de despliegue
NODE_ENV="development" # cambiar a "production" en Elastic Beanstalk
